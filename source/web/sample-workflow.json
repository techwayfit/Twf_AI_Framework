{
  "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
  "name": "Customer Support Chatbot",
  "description": "An AI-powered chatbot workflow that processes customer inquiries, analyzes sentiment, and generates appropriate responses",
  "createdAt": "2024-03-20T10:00:00Z",
  "updatedAt": "2024-03-20T15:30:00Z",
  "nodes": [
    {
  "id": "node-001",
      "name": "Input Validator",
      "type": "FilterNode",
      "category": "Data",
  "parameters": {
      "filterCondition": "input.length > 0",
        "errorMessage": "Input cannot be empty"
      },
      "position": {
        "x": 100,
        "y": 200
      },
      "color": "#7ED321"
    },
    {
      "id": "node-002",
   "name": "Build Context Prompt",
      "type": "PromptBuilderNode",
 "category": "AI",
      "parameters": {
        "template": "You are a helpful customer support agent. Customer question: {{input}}",
        "variables": ["input"]
 },
      "position": {
        "x": 350,
      "y": 200
      },
      "color": "#4A90E2"
    },
  {
      "id": "node-003",
      "name": "Sentiment Analysis",
      "type": "LlmNode",
      "category": "AI",
   "parameters": {
        "model": "gpt-4",
   "temperature": 0.3,
        "systemPrompt": "Analyze the sentiment of the customer message. Return only: positive, neutral, or negative"
      },
    "position": {
        "x": 350,
        "y": 350
      },
      "color": "#4A90E2"
    },
    {
      "id": "node-004",
      "name": "Route by Sentiment",
      "type": "SwitchNode",
      "category": "Control",
      "parameters": {
        "switchOn": "sentiment",
        "cases": ["positive", "neutral", "negative"]
      },
      "position": {
      "x": 600,
        "y": 300
      },
      "color": "#F5A623"
    },
    {
      "id": "node-005",
      "name": "Generate Positive Response",
      "type": "LlmNode",
      "category": "AI",
      "parameters": {
        "model": "gpt-4",
  "temperature": 0.7,
        "systemPrompt": "Generate a friendly, enthusiastic response to the customer's positive feedback"
      },
      "position": {
        "x": 850,
        "y": 150
      },
  "color": "#4A90E2"
  },
    {
      "id": "node-006",
    "name": "Generate Neutral Response",
      "type": "LlmNode",
      "category": "AI",
      "parameters": {
    "model": "gpt-4",
        "temperature": 0.7,
        "systemPrompt": "Generate a helpful, informative response to the customer's inquiry"
      },
      "position": {
    "x": 850,
        "y": 300
      },
  "color": "#4A90E2"
    },
    {
   "id": "node-007",
      "name": "Generate Empathetic Response",
      "type": "LlmNode",
      "category": "AI",
      "parameters": {
    "model": "gpt-4",
   "temperature": 0.7,
        "systemPrompt": "Generate an empathetic, solution-focused response to address the customer's concern"
      },
      "position": {
        "x": 850,
        "y": 450
      },
    "color": "#4A90E2"
    },
    {
    "id": "node-008",
      "name": "Merge Responses",
      "type": "MergeNode",
      "category": "Data",
      "parameters": {
        "mergeStrategy": "first-available"
      },
      "position": {
        "x": 1100,
        "y": 300
   },
      "color": "#7ED321"
    },
    {
      "id": "node-009",
    "name": "Format Output",
  "type": "OutputParserNode",
      "category": "AI",
      "parameters": {
        "outputFormat": "json",
        "schema": {
   "response": "string",
      "sentiment": "string",
          "timestamp": "datetime"
  }
      },
      "position": {
        "x": 1350,
    "y": 300
      },
      "color": "#4A90E2"
    },
    {
      "id": "node-010",
      "name": "Log Interaction",
      "type": "FileWriteNode",
      "category": "IO",
      "parameters": {
        "filePath": "logs/interactions.jsonl",
        "appendMode": true
      },
      "position": {
        "x": 1350,
        "y": 450
      },
      "color": "#BD10E0"
    }
