@model IEnumerable<TwfAiFramework.Web.Data.NodeTypeEntity>

@{
    ViewData["Title"] = "Node Types";
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
    var selectedCategory = ViewBag.SelectedCategory as string;
}

<div class="container-fluid mt-4">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-1"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row mb-3 align-items-center">
        <div class="col">
            <h1 class="mb-0"><i class="bi bi-puzzle"></i> Node Types</h1>
            <small class="text-muted">Manage node definitions used in the workflow designer</small>
        </div>
        <div class="col-auto">
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add Node Type
            </a>
        </div>
    </div>

    <!-- Category filter tabs -->
    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <a class="nav-link @(selectedCategory == null ? "active" : "")"
               asp-action="Index">All</a>
        </li>
        @foreach (var cat in categories)
        {
            <li class="nav-item">
                <a class="nav-link @(selectedCategory == cat ? "active" : "")"
                   asp-action="Index" asp-route-category="@cat">@cat</a>
            </li>
        }
    </ul>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No node types found.
            <a asp-action="Create">Add your first node type</a>.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:40px"></th>
                        <th>Node Type</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Description</th>
                        <th>Enabled</th>
                        <th>Updated</th>
                        <th style="width:180px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var node in Model)
                    {
                        <tr class="@(node.IsEnabled ? "" : "table-secondary text-muted")">
                            <td class="text-center">
                                <span style="color:@node.Color; font-size:1.3rem;">
                                    <i class="bi @node.Icon"></i>
                                </span>
                            </td>
                            <td><code>@node.NodeType</code></td>
                            <td>@node.Name</td>
                            <td>
                                <span class="badge rounded-pill"
                                      style="background-color:@node.Color">@node.Category</span>
                            </td>
                            <td class="text-truncate" style="max-width:280px"
                                title="@node.Description">@node.Description</td>
                            <td>
                                @if (node.IsEnabled)
                                {
                                    <span class="badge bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No</span>
                                }
                            </td>
                            <td><small class="text-muted">@node.UpdatedAt.ToString("g")</small></td>
                            <td>
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-action="Edit" asp-route-id="@node.Id"
                                       class="btn btn-outline-primary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <form asp-action="ToggleEnabled" asp-route-id="@node.Id"
                                          method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-outline-secondary"
                                                title="@(node.IsEnabled ? "Disable" : "Enable")">
                                            <i class="bi @(node.IsEnabled ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                        </button>
                                    </form>
                                    <a asp-action="Delete" asp-route-id="@node.Id"
                                       class="btn btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <small class="text-muted">@Model.Count() node type(s)</small>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
