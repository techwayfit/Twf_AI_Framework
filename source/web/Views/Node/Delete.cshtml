@model TwfAiFramework.Web.Data.NodeTypeEntity

@{
    ViewData["Title"] = $"Delete — {Model.Name}";
}

<div class="container mt-4" style="max-width:600px">
    <h1 class="text-danger"><i class="bi bi-trash"></i> Delete Node Type</h1>
    <hr />

    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle-fill me-1"></i>
        This action is <strong>permanent</strong>. Any workflows that reference
        <code>@Model.NodeType</code> will no longer have a palette entry.
    </div>

    <dl class="row">
        <dt class="col-sm-4">Node Type</dt>
        <dd class="col-sm-8"><code>@Model.NodeType</code></dd>

        <dt class="col-sm-4">Name</dt>
        <dd class="col-sm-8">@Model.Name</dd>

        <dt class="col-sm-4">Category</dt>
        <dd class="col-sm-8">
            <span class="badge rounded-pill" style="background-color:@Model.Color">
                @Model.Category
            </span>
        </dd>

        <dt class="col-sm-4">Description</dt>
        <dd class="col-sm-8">@Model.Description</dd>

        <dt class="col-sm-4">Enabled</dt>
        <dd class="col-sm-8">@(Model.IsEnabled ? "Yes" : "No")</dd>
    </dl>

    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-flex gap-2 mt-3">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash"></i> Yes, Delete
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
