@model TwfAiFramework.Web.Data.NodeTypeEntity

@{
    ViewData["Title"] = $"Edit — {Model.Name}";
}

<div class="container mt-4" style="max-width:860px">
    <h1>
        <span style="color:@Model.Color"><i class="bi @Model.Icon"></i></span>
        Edit: @Model.Name
    </h1>
    <hr />

    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedAt" />

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="NodeType" class="form-label fw-semibold">
                    Node Type <span class="text-danger">*</span>
                </label>
                <input asp-for="NodeType" class="form-control font-monospace" />
                <span asp-validation-for="NodeType" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Name" class="form-label fw-semibold">
                    Display Name <span class="text-danger">*</span>
                </label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Category" class="form-label fw-semibold">Category</label>
                <select asp-for="Category" class="form-select">
                    @foreach (var cat in new[] { "Control","Data","IO","Logic","AI","Visual" })
                    {
                        <option value="@cat" selected="@(Model.Category == cat)">@cat</option>
                    }
                </select>
                <span asp-validation-for="Category" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Color" class="form-label fw-semibold">Color</label>
                <div class="input-group">
                    <input asp-for="Color" type="color" class="form-control form-control-color"
                           style="max-width:60px" />
                    <input type="text" id="colorText" class="form-control font-monospace"
                           value="@Model.Color" maxlength="20"
                           oninput="document.getElementById('Color').value=this.value" />
                </div>
            </div>
            <div class="col-md-4">
                <label asp-for="Icon" class="form-label fw-semibold">Bootstrap Icon</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i id="iconPreview" class="bi @Model.Icon" style="color:@Model.Color"></i>
                    </span>
                    <input asp-for="Icon" class="form-control font-monospace"
                           oninput="document.getElementById('iconPreview').className='bi '+this.value" />
                </div>
                <div class="form-text">
                    <a href="https://icons.getbootstrap.com/" target="_blank" rel="noopener">Browse icons</a>
                </div>
            </div>

            <div class="col-12">
                <label asp-for="Description" class="form-label fw-semibold">Description</label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <div class="form-check">
                    <input asp-for="IsEnabled" class="form-check-input" type="checkbox" />
                    <label class="form-check-label" asp-for="IsEnabled">
                        Enabled — show in designer palette
                    </label>
                </div>
            </div>

            <div class="col-12">
                <label asp-for="SchemaJson" class="form-label fw-semibold">Schema JSON</label>
                <textarea asp-for="SchemaJson" class="form-control font-monospace"
                          rows="22" style="font-size:0.82rem"></textarea>
                <span asp-validation-for="SchemaJson" class="text-danger small"></span>
                <div class="form-text">
                    Serialised <code>NodeParameterSchema</code> — parameters, ports, capabilities.
                </div>
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-circle"></i> Save Changes
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            <a asp-action="Delete" asp-route-id="@Model.Id"
               class="btn btn-outline-danger ms-auto">
                <i class="bi bi-trash"></i> Delete
            </a>
        </div>
    </form>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('Color').addEventListener('input', function () {
            document.getElementById('colorText').value = this.value;
            document.getElementById('iconPreview').style.color = this.value;
        });
    </script>
}
