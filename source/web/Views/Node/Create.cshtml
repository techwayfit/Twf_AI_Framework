@model TwfAiFramework.Web.Data.NodeTypeEntity

@{
    ViewData["Title"] = "Add Node Type";
}

<div class="container mt-4" style="max-width:860px">
    <h1><i class="bi bi-plus-circle"></i> Add Node Type</h1>
    <hr />

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="NodeType" class="form-label fw-semibold">
                    Node Type <span class="text-danger">*</span>
                </label>
                <input asp-for="NodeType" class="form-control font-monospace"
                       placeholder="e.g. MyCustomNode" />
                <span asp-validation-for="NodeType" class="text-danger small"></span>
                <div class="form-text">Unique identifier used in workflow JSON (PascalCase, ends with "Node").</div>
            </div>
            <div class="col-md-6">
                <label asp-for="Name" class="form-label fw-semibold">
                    Display Name <span class="text-danger">*</span>
                </label>
                <input asp-for="Name" class="form-control" placeholder="e.g. My Custom Node" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="col-md-4">
                <label asp-for="Category" class="form-label fw-semibold">
                    Category <span class="text-danger">*</span>
                </label>
                <select asp-for="Category" class="form-select">
                    <option value="">-- Select --</option>
                    @foreach (var cat in new[] { "Control","Data","IO","Logic","AI","Visual" })
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
                <span asp-validation-for="Category" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Color" class="form-label fw-semibold">Color</label>
                <div class="input-group">
                    <input asp-for="Color" type="color" class="form-control form-control-color"
                           style="max-width:60px" />
                    <input type="text" id="colorText" class="form-control font-monospace"
                           value="@Model.Color" maxlength="20"
                           oninput="document.getElementById('Color').value=this.value"
                           placeholder="#888888" />
                </div>
                <span asp-validation-for="Color" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Icon" class="form-label fw-semibold">Bootstrap Icon</label>
                <div class="input-group">
                    <span class="input-group-text">
                        <i id="iconPreview" class="bi @Model.Icon"></i>
                    </span>
                    <input asp-for="Icon" class="form-control font-monospace"
                           placeholder="bi-box"
                           oninput="document.getElementById('iconPreview').className='bi '+this.value" />
                </div>
                <div class="form-text">
                    <a href="https://icons.getbootstrap.com/" target="_blank" rel="noopener">Browse icons</a>
                </div>
            </div>

            <div class="col-12">
                <label asp-for="Description" class="form-label fw-semibold">Description</label>
                <textarea asp-for="Description" class="form-control" rows="2"
                          placeholder="Brief description shown in the node palette"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <label asp-for="IsEnabled" class="form-label fw-semibold">Enabled</label>
                <div class="form-check">
                    <input asp-for="IsEnabled" class="form-check-input" type="checkbox" />
                    <label class="form-check-label" asp-for="IsEnabled">
                        Show this node in the designer palette
                    </label>
                </div>
            </div>

            <div class="col-12">
                <label asp-for="SchemaJson" class="form-label fw-semibold">Schema JSON</label>
                <textarea asp-for="SchemaJson" class="form-control font-monospace"
                          rows="18" style="font-size:0.82rem"
                          placeholder='{ "nodeType": "", "description": "", "parameters": [], "inputPorts": [], "outputPorts": [] }'></textarea>
                <span asp-validation-for="SchemaJson" class="text-danger small"></span>
                <div class="form-text">
                    Serialised <code>NodeParameterSchema</code> object defining parameters, ports, and capabilities.
                </div>
            </div>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-check-circle"></i> Create
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Keep hex text box in sync with colour picker
        document.getElementById('Color').addEventListener('input', function () {
            document.getElementById('colorText').value = this.value;
        });
    </script>
}
