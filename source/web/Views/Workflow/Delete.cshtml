@model TwfAiFramework.Web.Models.WorkflowDefinition

@{
 ViewData["Title"] = "Delete Workflow";
}

<div class="container mt-4">
<div class="row">
        <div class="col-md-8 offset-md-2">
   <div class="alert alert-danger">
     <h3><i class="bi bi-exclamation-triangle"></i> Confirm Delete</h3>
         <p>Are you sure you want to delete this workflow?</p>
  </div>

  <div class="card">
    <div class="card-body">
    <h4>@Model.Name</h4>
 <p class="text-muted">@(Model.Description ?? "No description")</p>
          
     <dl class="row">
   <dt class="col-sm-3">Created:</dt>
     <dd class="col-sm-9">@Model.CreatedAt.ToString("g")</dd>

   <dt class="col-sm-3">Last Updated:</dt>
 <dd class="col-sm-9">@Model.UpdatedAt.ToString("g")</dd>

     <dt class="col-sm-3">Nodes:</dt>
 <dd class="col-sm-9">@Model.Nodes.Count</dd>

  <dt class="col-sm-3">Connections:</dt>
   <dd class="col-sm-9">@Model.Connections.Count</dd>
    </dl>
 </div>
   </div>

  <form asp-action="Delete" method="post" class="mt-3">
  @Html.AntiForgeryToken()
<input type="hidden" asp-for="Id" />
       
      <div class="d-grid gap-2 d-md-flex justify-content-md-end">
    <a asp-action="Index" class="btn btn-secondary">
       <i class="bi bi-x-circle"></i> Cancel
      </a>
    <button type="submit" class="btn btn-danger">
         <i class="bi bi-trash"></i> Delete Permanently
    </button>
    </div>
 </form>
 </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
