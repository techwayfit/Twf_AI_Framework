@model IEnumerable<TwfAiFramework.Web.Models.WorkflowDefinition>

@{
    ViewData["Title"] = "Workflows";
}

<div class="container mt-4">
    <div class="row mb-4">
      <div class="col-md-6">
            <h1>
   <i class="bi bi-diagram-3"></i> Workflows
            </h1>
        </div>
        <div class="col-md-6 text-end">
            <a asp-action="Create" class="btn btn-primary">
      <i class="bi bi-plus-circle"></i> Create New Workflow
            </a>
      </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-6">
        <form asp-action="Index" method="get" class="d-flex">
     <input type="text" name="search" class="form-control me-2" placeholder="Search workflows..." value="@ViewBag.SearchQuery" />
    <button type="submit" class="btn btn-outline-secondary">
   <i class="bi bi-search"></i> Search
       </button>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
  <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No workflows found. <a asp-action="Create">Create your first workflow</a>.
     </div>
    }
    else
    {
        <div class="row">
      @foreach (var workflow in Model)
          {
       <div class="col-md-6 col-lg-4 mb-4">
      <div class="card h-100 shadow-sm">
         <div class="card-body">
    <h5 class="card-title">@workflow.Name</h5>
          <p class="card-text text-muted">@(workflow.Description ?? "No description")</p>
   
     <div class="mb-2">
   <small class="text-muted">
       <i class="bi bi-diagram-2"></i> @workflow.Nodes.Count nodes
   <span class="ms-2"><i class="bi bi-arrows-angle-contract"></i> @workflow.Connections.Count connections</span>
           </small>
   </div>

             @if (workflow.Metadata.Tags.Any())
     {
                <div class="mb-2">
  @foreach (var tag in workflow.Metadata.Tags)
      {
       <span class="badge bg-secondary me-1">@tag</span>
           }
      </div>
   }

     <small class="text-muted d-block mb-2">
      <i class="bi bi-clock"></i> Updated @workflow.UpdatedAt.ToString("g")
           </small>
     </div>
             <div class="card-footer bg-transparent">
       <div class="btn-group w-100" role="group">
          <a asp-action="Designer" asp-route-id="@workflow.Id" class="btn btn-primary btn-sm">
     <i class="bi bi-pencil-square"></i> Design
         </a>
        <a asp-action="Details" asp-route-id="@workflow.Id" class="btn btn-info btn-sm">
          <i class="bi bi-eye"></i> View
        </a>
          <a asp-action="Delete" asp-route-id="@workflow.Id" class="btn btn-danger btn-sm">
             <i class="bi bi-trash"></i> Delete
        </a>
   </div>
   </div>
  </div>
      </div>
            }
        </div>
    }
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
