@model IEnumerable<TwfAiFramework.Web.Models.WorkflowInstance>
@using TwfAiFramework.Web.Models

@{
    ViewData["Title"] = "Run History - " + ViewBag.WorkflowName;
    var workflowId = (Guid)ViewBag.WorkflowId;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-clock-history"></i> Run History</h1>
        <div>
            <a asp-action="Runner" asp-route-id="@workflowId" class="btn btn-success">
                <i class="bi bi-play-circle"></i> Run Again
            </a>
            <a asp-action="Details" asp-route-id="@workflowId" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <p class="text-muted">Workflow: <strong>@ViewBag.WorkflowName</strong></p>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No runs yet. Use the Runner to execute this workflow.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Started</th>
                        <th>Status</th>
                        <th>Duration</th>
                        <th>Steps</th>
                        <th>Error</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var run in Model)
                    {
                        var duration = run.CompletedAt.HasValue
                            ? (run.CompletedAt.Value - run.StartedAt).TotalSeconds.ToString("F1") + "s"
                            : "—";

                        var badgeClass = run.Status switch
                        {
                            WorkflowRunStatus.Completed => "bg-success",
                            WorkflowRunStatus.Failed    => "bg-danger",
                            WorkflowRunStatus.Running   => "bg-primary",
                            _                           => "bg-secondary"
                        };

                        <tr>
                            <td>@run.StartedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td><span class="badge @badgeClass">@run.Status</span></td>
                            <td>@duration</td>
                            <td>@run.Steps.Count</td>
                            <td class="text-danger small">@run.ErrorMessage</td>
                            <td>
                                <a asp-action="RunDetail" asp-route-instanceId="@run.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-card-list"></i> Details
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
