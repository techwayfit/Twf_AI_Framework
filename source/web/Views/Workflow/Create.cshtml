@model TwfAiFramework.Web.Models.WorkflowDefinition

@{
 ViewData["Title"] = "Create Workflow";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <h1><i class="bi bi-plus-circle"></i> Create New Workflow</h1>
   
 <form asp-action="Create" method="post" class="mt-4">
      @Html.AntiForgeryToken()
       
   <div class="mb-3">
       <label asp-for="Name" class="form-label">Workflow Name</label>
        <input asp-for="Name" class="form-control" required />
             <span asp-validation-for="Name" class="text-danger"></span>
     </div>

     <div class="mb-3">
     <label asp-for="Description" class="form-label">Description</label>
      <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
       </div>

    <div class="mb-3">
  <label class="form-label">Tags (comma-separated)</label>
       <input type="text" class="form-control" id="tags-input" placeholder="e.g., AI, automation, data-processing" />
   </div>

  <div class="mb-3">
   <label asp-for="Metadata.Author" class="form-label">Author</label>
       <input asp-for="Metadata.Author" class="form-control" />
       </div>

        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
      <a asp-action="Index" class="btn btn-secondary">
           <i class="bi bi-x-circle"></i> Cancel
        </a>
          <button type="submit" class="btn btn-primary">
    <i class="bi bi-check-circle"></i> Create & Open Designer
       </button>
    </div>
 </form>
  </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
