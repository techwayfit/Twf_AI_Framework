@model TwfAiFramework.Web.Models.WorkflowDefinition

@{
  ViewData["Title"] = "Workflow Details - " + Model.Name;
}

<div class="container mt-4">
  <div class="row">
 <div class="col-md-10 offset-md-1">
    <div class="d-flex justify-content-between align-items-start mb-4">
   <h1><i class="bi bi-diagram-3"></i> @Model.Name</h1>
    <div>
        <a asp-action="Runner" asp-route-id="@Model.Id" class="btn btn-success">
          <i class="bi bi-play-circle"></i> Run
        </a>
        <a asp-action="Runs" asp-route-id="@Model.Id" class="btn btn-outline-secondary">
          <i class="bi bi-clock-history"></i> Run History
        </a>
        <a asp-action="Designer" asp-route-id="@Model.Id" class="btn btn-primary">
          <i class="bi bi-pencil-square"></i> Edit in Designer
        </a>
        <a asp-action="Index" class="btn btn-secondary">
          <i class="bi bi-arrow-left"></i> Back to List
        </a>
   </div>
 </div>

       <div class="card mb-4">
<div class="card-header">
   <h5>Workflow Information</h5>
</div>
    <div class="card-body">
    <dl class="row">
     <dt class="col-sm-3">Description:</dt>
        <dd class="col-sm-9">@(Model.Description ?? "No description provided")</dd>

  <dt class="col-sm-3">Created:</dt>
   <dd class="col-sm-9">@Model.CreatedAt.ToString("F")</dd>

   <dt class="col-sm-3">Last Updated:</dt>
      <dd class="col-sm-9">@Model.UpdatedAt.ToString("F")</dd>

       <dt class="col-sm-3">Author:</dt>
   <dd class="col-sm-9">@(Model.Metadata.Author ?? "Unknown")</dd>

      <dt class="col-sm-3">Version:</dt>
<dd class="col-sm-9">@Model.Metadata.Version</dd>

    <dt class="col-sm-3">Status:</dt>
    <dd class="col-sm-9">
         <span class="badge @(Model.Metadata.IsActive ? "bg-success" : "bg-secondary")">
        @(Model.Metadata.IsActive ? "Active" : "Inactive")
   </span>
 </dd>

   @if (Model.Metadata.Tags.Any())
 {
    <dt class="col-sm-3">Tags:</dt>
  <dd class="col-sm-9">
       @foreach (var tag in Model.Metadata.Tags)
     {
  <span class="badge bg-secondary me-1">@tag</span>
  }
    </dd>
        }
</dl>
            </div>
        </div>

  <div class="card mb-4">
  <div class="card-header">
    <h5>Workflow Statistics</h5>
 </div>
       <div class="card-body">
      <div class="row text-center">
 <div class="col-md-4">
    <div class="border rounded p-3">
       <h2 class="text-primary">@Model.Nodes.Count</h2>
    <p class="text-muted mb-0">Nodes</p>
     </div>
       </div>
          <div class="col-md-4">
<div class="border rounded p-3">
 <h2 class="text-success">@Model.Connections.Count</h2>
       <p class="text-muted mb-0">Connections</p>
       </div>
    </div>
<div class="col-md-4">
      <div class="border rounded p-3">
   <h2 class="text-info">@Model.Nodes.GroupBy(n => n.Category).Count()</h2>
     <p class="text-muted mb-0">Categories</p>
   </div>
         </div>
    </div>
    </div>
  </div>

   @if (Model.Nodes.Any())
        {
      <div class="card mb-4">
       <div class="card-header">
    <h5>Nodes in Workflow</h5>
   </div>
 <div class="card-body">
       <div class="table-responsive">
        <table class="table table-hover">
 <thead>
       <tr>
 <th>Name</th>
    <th>Type</th>
 <th>Category</th>
        <th>Parameters</th>
     </tr>
       </thead>
     <tbody>
        @foreach (var node in Model.Nodes)
         {
      <tr>
            <td><strong>@node.Name</strong></td>
         <td>@node.Type</td>
      <td><span class="badge bg-info">@node.Category</span></td>
         <td>@node.Parameters.Count parameter(s)</td>
     </tr>
         }
     </tbody>
   </table>
    </div>
  </div>
 </div>
   }

  @if (Model.Connections.Any())
  {
   <div class="card mb-4">
    <div class="card-header">
    <h5>Connections</h5>
       </div>
       <div class="card-body">
   <ul class="list-group">
  @foreach (var conn in Model.Connections)
    {
      var sourceNode = Model.Nodes.FirstOrDefault(n => n.Id == conn.SourceNodeId);
    var targetNode = Model.Nodes.FirstOrDefault(n => n.Id == conn.TargetNodeId);
     <li class="list-group-item">
          <i class="bi bi-arrow-right-circle"></i>
    <strong>@(sourceNode?.Name ?? "Unknown")</strong> 
       ?
      <strong>@(targetNode?.Name ?? "Unknown")</strong>
   </li>
      }
      </ul>
        </div>
   </div>
        }

  <div class="d-flex justify-content-between">
 <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">
      <i class="bi bi-trash"></i> Delete Workflow
    </a>
  <a asp-action="Runner" asp-route-id="@Model.Id" class="btn btn-success">
        <i class="bi bi-play-circle"></i> Run Workflow
    </a>
    <a asp-action="Designer" asp-route-id="@Model.Id" class="btn btn-primary">
        <i class="bi bi-pencil-square"></i> Open in Designer
    </a>
     </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
