@model TwfAiFramework.Web.Models.WorkflowInstance
@using TwfAiFramework.Web.Models

@{
    ViewData["Title"] = "Run Detail";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-card-list"></i> Run Detail</h1>
        <a asp-controller="WorkflowRunner" asp-action="Runs" asp-route-id="@Model.WorkflowDefinitionId" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Back to Run History
        </a>
    </div>

    @{
        var badgeClass = Model.Status switch
        {
            WorkflowRunStatus.Completed => "bg-success",
            WorkflowRunStatus.Failed    => "bg-danger",
            WorkflowRunStatus.Running   => "bg-primary",
            _                           => "bg-secondary"
        };
        var duration = Model.CompletedAt.HasValue
            ? (Model.CompletedAt.Value - Model.StartedAt).TotalSeconds.ToString("F1") + "s"
            : "In progress…";
    }

    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <strong>@Model.WorkflowName</strong>
            <span class="badge @badgeClass fs-6">@Model.Status</span>
        </div>
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">Instance ID</dt>
                <dd class="col-sm-9 font-monospace text-muted small">@Model.Id</dd>

                <dt class="col-sm-3">Started</dt>
                <dd class="col-sm-9">@Model.StartedAt.ToString("yyyy-MM-dd HH:mm:ss UTC")</dd>

                <dt class="col-sm-3">Completed</dt>
                <dd class="col-sm-9">@(Model.CompletedAt?.ToString("yyyy-MM-dd HH:mm:ss UTC") ?? "—")</dd>

                <dt class="col-sm-3">Duration</dt>
                <dd class="col-sm-9">@duration</dd>

                @if (Model.ErrorMessage is not null)
                {
                    <dt class="col-sm-3 text-danger">Error</dt>
                    <dd class="col-sm-9 text-danger">@Model.ErrorMessage</dd>
                }
                @if (Model.FailedNodeName is not null)
                {
                    <dt class="col-sm-3 text-danger">Failed Node</dt>
                    <dd class="col-sm-9 text-danger">@Model.FailedNodeName</dd>
                }
            </dl>
        </div>
    </div>

    @if (Model.Steps.Any())
    {
        @* Show one card per node (node_done / node_error), skip node_start duplicates *@
        var nodeFinalSteps = Model.Steps
            .Where(s => s.EventType is "node_done" or "node_error")
            .ToList();

        <h5 class="mb-3"><i class="bi bi-list-ol"></i> Step Log (@nodeFinalSteps.Count nodes)</h5>
        <div class="timeline">
            @foreach (var step in nodeFinalSteps)
            {
                var isError  = step.EventType == "node_error";
                var iconClass = isError ? "bi-x-circle-fill text-danger" : "bi-check-circle-fill text-success";
                var borderCls = isError ? "border-danger" : "";
                var jsonOpts  = new System.Text.Json.JsonSerializerOptions { WriteIndented = true };

                <div class="card mb-2 @borderCls">
                    <div class="card-body py-2 px-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>
                                <i class="bi @iconClass me-1"></i>
                                <strong>@step.NodeName</strong>
                                <span class="badge bg-light text-dark ms-1">@step.NodeType</span>
                            </span>
                            <small class="text-muted">@step.Timestamp.ToString("HH:mm:ss.fff")</small>
                        </div>

                        @if (step.ErrorMessage is not null)
                        {
                            <div class="text-danger small mt-1">@step.ErrorMessage</div>
                        }

                        <details class="mt-2" open>
                            <summary class="text-muted small" style="cursor:pointer">Data In / Data Out</summary>
                            <div class="row g-2 mt-1">
                                <div class="col-md-6">
                                    <div class="fw-semibold small text-muted mb-1">Data In</div>
                                    @if (step.DataInConfigured)
                                    {
                                        <pre class="p-2 bg-light rounded small mb-0" style="max-height:200px;overflow:auto">@System.Text.Json.JsonSerializer.Serialize(step.InputData, jsonOpts)</pre>
                                    }
                                    else
                                    {
                                        <p class="text-muted fst-italic small mb-0">No Data in/out is configured</p>
                                    }
                                </div>
                                <div class="col-md-6">
                                    <div class="fw-semibold small text-muted mb-1">Data Out</div>
                                    @if (step.DataOutConfigured)
                                    {
                                        <pre class="p-2 bg-light rounded small mb-0" style="max-height:200px;overflow:auto">@System.Text.Json.JsonSerializer.Serialize(step.OutputData, jsonOpts)</pre>
                                    }
                                    else
                                    {
                                        <p class="text-muted fst-italic small mb-0">No Data in/out is configured</p>
                                    }
                                </div>
                            </div>
                        </details>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">No step events recorded.</p>
    }

    @if (Model.OutputData.Any())
    {
        <div class="card mt-4">
            <div class="card-header"><strong>Final Output Data</strong></div>
            <div class="card-body">
                <pre class="mb-0 small">@System.Text.Json.JsonSerializer.Serialize(Model.OutputData, new System.Text.Json.JsonSerializerOptions { WriteIndented = true })</pre>
            </div>
        </div>
    }
</div>
