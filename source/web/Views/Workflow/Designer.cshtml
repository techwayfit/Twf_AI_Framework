@model TwfAiFramework.Web.Models.WorkflowDefinition

@{
    ViewData["Title"] = "Workflow Designer - " + Model.Name;
    Layout = null; // Full-screen, no shared layout
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap (used by the React components for form controls and buttons) -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons (used inside React components with className="bi bi-*") -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" crossorigin="anonymous" />

    <!-- React Flow + designer styles (output of: cd designer-react && npm run build) -->
    <link rel="stylesheet" href="~/js/designer-app/designer.css" asp-append-version="true" />

    <style>
        html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; }
    </style>
</head>
<body>
    <!-- React mounts here -->
    <div id="designer-root"></div>

    <!-- Inject server-side config for the React app -->
    <script>
        window.__DESIGNER_CONFIG__ = {
            workflowId: '@Model.Id'
        };
    </script>

    <!-- React Flow designer bundle (output of: cd designer-react && npm run build) -->
    <script src="~/js/designer-app/designer.js" asp-append-version="true"></script>
</body>
</html>
