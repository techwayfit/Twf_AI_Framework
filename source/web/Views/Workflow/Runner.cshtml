@model TwfAiFramework.Web.Models.WorkflowDefinition

@{
    ViewData["Title"] = "Runner - " + Model.Name;
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <!-- Reuse designer node / connection styles for the read-only canvas -->
    <link rel="stylesheet" href="~/css/designer/designer-base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/designer/designer-nodes.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/designer/designer-ports.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/designer/designer-connections.css" asp-append-version="true" />

    <!-- Runner-specific styles -->
    <link rel="stylesheet" href="~/css/runner.css" asp-append-version="true" />
</head>
<body>
<div id="runner-container">

    <!-- ── Toolbar ──────────────────────────────────────────────────────── -->
    <div id="runner-toolbar">
        <div class="toolbar-left">
            <a href="@Url.Action("Designer", new { id = Model.Id })" class="btn-toolbar" title="Back to designer">
                <i class="bi bi-pencil-square"></i> Edit
            </a>
            <h5><i class="bi bi-play-circle-fill"></i> <span id="workflow-name">@Model.Name</span></h5>
        </div>
        <div class="toolbar-right">
            <span id="run-status-badge" class="badge bg-secondary">Ready</span>
            <button class="btn-toolbar btn-run-action" id="btn-run" onclick="showInputModal()">
                <i class="bi bi-play-fill"></i> Run
            </button>
            <button class="btn-toolbar btn-stop-action" id="btn-stop" onclick="stopRun()" disabled>
                <i class="bi bi-stop-fill"></i> Stop
            </button>
        </div>
    </div>

    <!-- ── Main area ────────────────────────────────────────────────────── -->
    <div id="runner-main-area">

        <!-- Read-only canvas (same DOM structure as the designer) -->
        <div id="canvas-area">
            <svg id="workflow-canvas" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <marker id="arrowhead" markerWidth="10" markerHeight="6" refX="5" refY="3" orient="auto" markerUnits="strokeWidth">
                        <polygon points="0 0, 10 3, 0 6" fill="#3498db" />
                    </marker>
                    <marker id="arrowhead-selected" markerWidth="10" markerHeight="6" refX="5" refY="3" orient="auto" markerUnits="strokeWidth">
                        <polygon points="0 0, 10 3, 0 6" fill="#c0392b" />
                    </marker>
                </defs>
                <g id="connections-layer"></g>
                <g id="temp-connection-layer"></g>
            </svg>
            <div id="nodes-layer"></div>
        </div>

        <!-- Execution log / step panel -->
        <div id="step-panel">
            <div id="step-panel-header">
                <h6><i class="bi bi-list-check"></i> Execution Log</h6>
                <button class="btn btn-sm btn-outline-secondary" onclick="clearLog()" title="Clear log">
                    <i class="bi bi-trash"></i>
                </button>
            </div>
            <div id="step-cards"></div>
        </div>

    </div>
</div>

<!-- ── Input Modal ──────────────────────────────────────────────────────── -->
<div id="input-modal" class="modal-overlay" style="display:none;" onclick="onModalOverlayClick(event)">
    <div class="modal-box">
        <h5><i class="bi bi-input-cursor-text"></i> Workflow Inputs</h5>
        <p class="text-muted small">Provide initial data for the workflow. Leave empty to start with no inputs.</p>
        <div id="input-fields"></div>
        <button class="btn btn-link btn-sm ps-0" onclick="addInputField()">
            <i class="bi bi-plus-circle"></i> Add field
        </button>
        <div class="modal-footer-btns">
            <button class="btn btn-secondary btn-sm" onclick="closeInputModal()">Cancel</button>
            <button class="btn btn-success btn-sm" id="btn-modal-run" onclick="startRun()">
                <i class="bi bi-play-fill"></i> Run Workflow
            </button>
        </div>
    </div>
</div>

<!-- ─────────────────────── Scripts ─────────────────────────────────────── -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>

<!-- Designer node architecture (needed for rendering) -->
<script src="~/js/designer/core/Constants.js" asp-append-version="true"></script>
<script src="~/js/designer/core/WorkflowData.js" asp-append-version="true"></script>
<script src="~/js/designer/core/BaseNode.js" asp-append-version="true"></script>
<script src="~/js/designer/core/NodeRegistry.js" asp-append-version="true"></script>

<!-- Node Classes - AI -->
<script src="~/js/designer/nodes/ai/LlmNode.js" asp-append-version="true"></script>
<script src="~/js/designer/nodes/ai/PromptBuilderNode.js" asp-append-version="true"></script>
<script src="~/js/designer/nodes/ai/EmbeddingNode.js" asp-append-version="true"></script>
<script src="~/js/designer/nodes/ai/OutputParserNode.js" asp-append-version="true"></script>

<!-- Node Classes - Control -->
<script src="~/js/designer/nodes/control/ConditionNode.js" asp-append-version="true"></script>
<script src="~/js/designer/nodes/control/ErrorNode.js" asp-append-version="true"></script>
<script src="~/js/designer/nodes/control/SubWorkflowNode.js" asp-append-version="true"></script>
<script src="~/js/designer/nodes/control/ErrorRouteNode.js" asp-append-version="true"></script>
<script src="~/js/designer/nodes/control/DelayNode.js" asp-append-version="true"></script>
<script src="~/js/designer/nodes/control/MergeNode.js" asp-append-version="true"></script>
<script src="~/js/designer/nodes/control/LogNode.js" asp-append-version="true"></script>
<script src="~/js/designer/nodes/control/LoopNode.js" asp-append-version="true"></script>

<!-- Node Classes - Data -->
<script src="~/js/designer/nodes/data/TransformNode.js" asp-append-version="true"></script>
<script src="~/js/designer/nodes/data/DataMapperNode.js" asp-append-version="true"></script>
<script src="~/js/designer/nodes/data/FilterNode.js" asp-append-version="true"></script>
<script src="~/js/designer/nodes/data/ChunkTextNode.js" asp-append-version="true"></script>
<script src="~/js/designer/nodes/data/MemoryNode.js" asp-append-version="true"></script>

<!-- Node Classes - IO -->
<script src="~/js/designer/nodes/io/HttpRequestNode.js" asp-append-version="true"></script>

<!-- Node Renderer -->
<script src="~/js/designer/ui/NodeRenderer.js" asp-append-version="true"></script>

<!-- Condition / Validators (needed by ConditionNode) -->
<script src="~/js/designer/utils/ExpressionValidator.js" asp-append-version="true"></script>
<script src="~/js/designer/utils/ConnectionValidator.js" asp-append-version="true"></script>

<!-- Start / End / Container nodes -->
<script src="~/js/designer/nodes/control/StartNode.js" asp-append-version="true"></script>
<script src="~/js/designer/nodes/control/EndNode.js" asp-append-version="true"></script>
<script src="~/js/designer/nodes/control/ParallelNode.js" asp-append-version="true"></script>
<script src="~/js/designer/nodes/control/BranchNode.js" asp-append-version="true"></script>

<!-- Designer shared state / utils / rendering (read-only — no events.js drag handlers) -->
<script src="~/js/designer/state.js" asp-append-version="true"></script>
<script src="~/js/designer/utils.js" asp-append-version="true"></script>
<script src="~/js/designer/variables.js" asp-append-version="true"></script>
<script src="~/js/designer/nodes.js" asp-append-version="true"></script>
<script src="~/js/designer/connections.js" asp-append-version="true"></script>
<script src="~/js/designer/rendering.js" asp-append-version="true"></script>

<!-- Main orchestrator -->
<script src="~/js/designer/core/Designer.js" asp-append-version="true"></script>

<!-- Runner-specific logic (loaded last) -->
<script src="~/js/runner.js" asp-append-version="true"></script>

<script>
    // Inject the server-side workflow definition as JS so runner.js can use it.
    // Use camelCase to match the casing returned by /Workflow/GetWorkflow (MVC default).
    const workflowId  = '@Model.Id';
    const workflowDef = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model,
        new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));

    // Bootstrap the runner after all scripts are loaded
    document.addEventListener('DOMContentLoaded', () => initRunner(workflowId, workflowDef));
</script>
</body>
</html>
