@model TwfAiFramework.Web.Models.WorkflowDefinition

@{
    ViewData["Title"] = "Runner - " + Model.Name;
    Layout = null; // Full-screen, no shared layout
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="~/js/designer-app/designer.css" asp-append-version="true" />

    <style>
        html, body { margin: 0; padding: 0; height: 100%; overflow: hidden; }
    </style>
</head>
<body>
    <div id="designer-root"></div>

    <script>
        window.__DESIGNER_CONFIG__ = {
            workflowId: '@Model.Id',
            mode: 'runner'
        };
    </script>

    <script src="~/js/designer-app/designer.js" asp-append-version="true"></script>
</body>
</html>
